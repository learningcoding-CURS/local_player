<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="12dp"
    android:layout_marginEnd="12dp"
    android:layout_marginTop="4dp"
    android:layout_marginBottom="4dp"
    app:cardBackgroundColor="@color/bgCard"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Index badge -->
            <TextView
                android:id="@+id/tvItemIndex"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:gravity="center"
                android:textColor="@color/colorAccentLight"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:background="@color/bgSurface" />

            <!-- File icon (video or audio) -->
            <ImageView
                android:id="@+id/ivMediaType"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_play_circle"
                android:tint="@color/textSecondary" />

            <TextView
                android:id="@+id/tvItemTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:textColor="@color/textPrimary"
                android:textSize="14sp"
                android:maxLines="2"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvItemProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:textColor="@color/colorAccentLight"
                android:textSize="11sp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Playback progress bar -->
        <ProgressBar
            android:id="@+id/itemProgressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:layout_marginTop="8dp"
            android:max="100"
            android:progressTint="@color/colorAccent"
            android:progressBackgroundTint="@color/seekbarBackground" />
    </LinearLayout>

</androidx.cardview.widget.CardView>
