<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- Video surface — ExoPlayer renders here -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/playerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:focusable="true" />

    <!-- Subtitle overlay — sits just above the controls -->
    <com.videomaster.app.ui.SubtitleView
        android:id="@+id/subtitleView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="80dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp" />

    <!-- Long-press speed hint -->
    <TextView
        android:id="@+id/tvLongPressHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="32dp"
        android:text="@string/long_press_speed"
        android:textColor="@color/colorAccentLight"
        android:textSize="16sp"
        android:fontFamily="sans-serif-medium"
        android:background="@drawable/bg_speed_badge"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:visibility="gone" />

    <!-- Buffering indicator -->
    <ProgressBar
        android:id="@+id/loadingView"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="center"
        android:indeterminateTint="@color/colorAccent"
        android:visibility="gone" />

    <!-- ─── Brightness indicator (left center) ─── -->
    <LinearLayout
        android:id="@+id/brightnessIndicator"
        android:layout_width="48dp"
        android:layout_height="200dp"
        android:layout_gravity="center_vertical|start"
        android:layout_marginStart="24dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#88000000"
        android:padding="8dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_brightness"
            android:tint="@color/textPrimary" />

        <!-- Vertical progress bar for brightness level -->
        <ProgressBar
            android:id="@+id/brightnessBar"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="8dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp"
            android:progressTint="@color/colorAccentLight"
            android:progressBackgroundTint="#44FFFFFF"
            android:max="100"
            android:rotation="270" />

        <TextView
            android:id="@+id/tvBrightnessValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="50%"
            android:textColor="@color/textPrimary"
            android:textSize="10sp" />
    </LinearLayout>

    <!-- ─── Volume indicator (right center) ─── -->
    <LinearLayout
        android:id="@+id/volumeIndicator"
        android:layout_width="48dp"
        android:layout_height="200dp"
        android:layout_gravity="center_vertical|end"
        android:layout_marginEnd="24dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#88000000"
        android:padding="8dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_speed"
            android:tint="@color/textPrimary" />

        <ProgressBar
            android:id="@+id/volumeBar"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="8dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp"
            android:progressTint="@color/colorAccentLight"
            android:progressBackgroundTint="#44FFFFFF"
            android:max="100"
            android:rotation="270" />

        <TextView
            android:id="@+id/tvVolumeValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="50%"
            android:textColor="@color/textPrimary"
            android:textSize="10sp" />
    </LinearLayout>

    <!-- ─────────────────── CONTROLS OVERLAY ─────────────────── -->
    <FrameLayout
        android:id="@+id/controlsOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/overlayBackground"
        android:visibility="visible">

        <!-- Top bar: lock | speed badge | subtitle | rotate buttons -->
        <LinearLayout
            android:id="@+id/topBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">

            <!-- Lock button (left side) -->
            <ImageButton
                android:id="@+id/btnLock"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_lock_open"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/controlTint"
                android:contentDescription="@string/btn_lock"
                android:layout_marginEnd="4dp" />

            <!-- Add to playlist button -->
            <ImageButton
                android:id="@+id/btnAddToPlaylist"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_playlist"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/controlTint"
                android:contentDescription="@string/btn_add_to_playlist"
                android:layout_marginEnd="4dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Current speed badge -->
            <TextView
                android:id="@+id/tvSpeed"
                style="@style/SpeedBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1×"
                android:layout_marginEnd="8dp" />

            <!-- Speed selector -->
            <ImageButton
                android:id="@+id/btnSpeed"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_speed"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/controlTint"
                android:contentDescription="@string/btn_speed"
                android:layout_marginEnd="4dp" />

            <!-- Subtitle -->
            <ImageButton
                android:id="@+id/btnSubtitle"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_subtitle"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/controlTint"
                android:contentDescription="@string/btn_subtitle"
                android:layout_marginEnd="4dp" />

            <!-- Rotate -->
            <ImageButton
                android:id="@+id/btnRotate"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_rotate"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/controlTint"
                android:contentDescription="@string/btn_rotate" />
        </LinearLayout>

        <!-- Centre playback row: rewind | play/pause | forward -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btnRewind"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_rewind"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/controlTint"
                android:contentDescription="@string/btn_rewind"
                android:padding="10dp" />

            <ImageButton
                android:id="@+id/btnPlayPause"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:src="@drawable/ic_play"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/controlTint"
                android:contentDescription="@string/btn_play"
                android:padding="8dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp" />

            <ImageButton
                android:id="@+id/btnForward"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_forward"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/controlTint"
                android:contentDescription="@string/btn_forward"
                android:padding="10dp" />
        </LinearLayout>

        <!-- Bottom bar: time + seekbar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp">

            <!-- Time row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="4dp">

                <TextView
                    android:id="@+id/tvCurrentTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textColor="@color/textPrimary"
                    android:textSize="13sp"
                    android:fontFamily="monospace" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/tvDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textColor="@color/textSecondary"
                    android:textSize="13sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <!-- SeekBar (max=1000 for 0.1% granularity) -->
            <SeekBar
                android:id="@+id/seekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="1000"
                android:progressTint="@color/seekbarProgress"
                android:thumbTint="@color/seekbarThumb"
                android:progressBackgroundTint="@color/seekbarBackground" />
        </LinearLayout>

    </FrameLayout>

    <!-- ─── Lock Overlay (shown when screen is locked) ─── -->
    <FrameLayout
        android:id="@+id/lockOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <!-- Unlock button — always visible when locked -->
        <ImageButton
            android:id="@+id/btnUnlock"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="top|start"
            android:layout_margin="16dp"
            android:src="@drawable/ic_lock"
            android:background="#88000000"
            android:tint="@color/colorAccentLight"
            android:contentDescription="@string/btn_unlock"
            android:padding="10dp" />
    </FrameLayout>

</FrameLayout>
