<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- Video surface — ExoPlayer renders here -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/playerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:focusable="true" />

    <!-- Subtitle overlay — sits just above the controls -->
    <com.videomaster.app.ui.SubtitleView
        android:id="@+id/subtitleView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="80dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp" />

    <!-- Long-press speed hint -->
    <TextView
        android:id="@+id/tvLongPressHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="32dp"
        android:text="@string/long_press_speed"
        android:textColor="@color/colorAccentLight"
        android:textSize="16sp"
        android:fontFamily="sans-serif-medium"
        android:background="@drawable/bg_speed_badge"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:visibility="gone" />

    <!-- Buffering indicator -->
    <ProgressBar
        android:id="@+id/loadingView"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="center"
        android:indeterminateTint="@color/colorAccent"
        android:visibility="gone" />

    <!-- ─── Brightness indicator (left edge, compact & translucent, no icon, no bar) ─── -->
    <LinearLayout
        android:id="@+id/brightnessIndicator"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center_vertical|start"
        android:layout_marginStart="8dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#88000000"
        android:padding="4dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvBrightnessValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="50%"
            android:textColor="@color/textPrimary"
            android:textSize="11sp"
            android:gravity="center" />
    </LinearLayout>

    <!-- ─────────────────── CONTROLS OVERLAY ─────────────────── -->
    <FrameLayout
        android:id="@+id/controlsOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/overlayBackground"
        android:visibility="visible">

        <!-- Top bar: lock | play-mode | space | speed | playlist-panel | subtitle | subtitle-list | rotate -->
        <LinearLayout
            android:id="@+id/topBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">

            <!-- Lock button -->
            <ImageButton
                android:id="@+id/btnLock"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_lock_open"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/controlTint"
                android:contentDescription="@string/btn_lock"
                android:layout_marginEnd="4dp" />

            <!-- Play mode toggle button -->
            <ImageButton
                android:id="@+id/btnPlayMode"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_mode_sequential"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/controlTint"
                android:contentDescription="@string/btn_play_mode"
                android:layout_marginEnd="4dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Speed badge + selector merged into one clickable TextView -->
            <TextView
                android:id="@+id/tvSpeed"
                style="@style/SpeedBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1×"
                android:layout_marginEnd="4dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:contentDescription="@string/btn_speed" />

            <!-- In-player playlist panel toggle — accent color, next to speed -->
            <ImageButton
                android:id="@+id/btnPlaylistPanel"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_playlist_panel"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/colorAccent"
                android:contentDescription="@string/btn_playlist_panel"
                android:layout_marginEnd="4dp" />

            <!-- Subtitle text visibility toggle (only hides/shows subtitle text, keeps list open) -->
            <ImageButton
                android:id="@+id/btnSubtitleToggle"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_subtitle_toggle"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/controlTint"
                android:contentDescription="@string/btn_subtitle_toggle"
                android:layout_marginEnd="4dp" />

            <!-- Subtitle import/export menu -->
            <ImageButton
                android:id="@+id/btnSubtitle"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_subtitle"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/controlTint"
                android:contentDescription="@string/btn_subtitle"
                android:layout_marginEnd="4dp" />

            <!-- Subtitle list panel toggle -->
            <ImageButton
                android:id="@+id/btnSubtitleList"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_subtitle_list"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/controlTint"
                android:contentDescription="@string/btn_subtitle_list"
                android:layout_marginEnd="4dp"
                android:visibility="gone" />

            <!-- Rotate -->
            <ImageButton
                android:id="@+id/btnRotate"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_rotate"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/controlTint"
                android:contentDescription="@string/btn_rotate"
                android:layout_marginEnd="4dp" />

            <!-- Settings -->
            <ImageButton
                android:id="@+id/btnPlayerSettings"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_settings"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/controlTint"
                android:contentDescription="@string/settings_title" />
        </LinearLayout>

        <!-- Centre controls: two rows stacked vertically -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <!-- Row 1: rewind | play/pause | forward -->
            <LinearLayout
                android:id="@+id/seekRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageButton
                    android:id="@+id/btnRewind"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/ic_rewind"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="@color/controlTint"
                    android:contentDescription="@string/btn_rewind"
                    android:scaleType="fitCenter"
                    android:padding="10dp" />

                <ImageButton
                    android:id="@+id/btnPlayPause"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:src="@drawable/ic_play"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="@color/controlTint"
                    android:contentDescription="@string/btn_play"
                    android:padding="8dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp" />

                <ImageButton
                    android:id="@+id/btnForward"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/ic_forward"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="@color/controlTint"
                    android:contentDescription="@string/btn_forward"
                    android:scaleType="fitCenter"
                    android:padding="10dp" />
            </LinearLayout>

            <!-- Row 2: skip-prev | skip-next (separate from seek buttons) -->
            <LinearLayout
                android:id="@+id/skipRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">

                <ImageButton
                    android:id="@+id/btnSkipPrev"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_skip_prev"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="@color/controlTint"
                    android:contentDescription="@string/btn_skip_prev"
                    android:scaleType="fitCenter"
                    android:padding="10dp"
                    android:layout_marginEnd="24dp" />

                <ImageButton
                    android:id="@+id/btnSkipNext"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_skip_next"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="@color/controlTint"
                    android:contentDescription="@string/btn_skip_next"
                    android:scaleType="fitCenter"
                    android:padding="10dp"
                    android:layout_marginStart="24dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Bottom bar: time + seekbar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp">

            <!-- Time row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="4dp">

                <TextView
                    android:id="@+id/tvCurrentTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textColor="@color/textPrimary"
                    android:textSize="13sp"
                    android:fontFamily="monospace" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/tvDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textColor="@color/textSecondary"
                    android:textSize="13sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <!-- SeekBar (max=1000 for 0.1% granularity) — thick track + larger thumb -->
            <SeekBar
                android:id="@+id/seekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="1000"
                android:progressDrawable="@drawable/seekbar_progress"
                android:thumb="@drawable/seekbar_thumb"
                android:splitTrack="false" />
        </LinearLayout>

    </FrameLayout>

    <!-- ─── In-player Playlist Panel (slides in from right) ─── -->
    <LinearLayout
        android:id="@+id/playlistPanel"
        android:layout_width="260dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:orientation="vertical"
        android:background="#DD0D0D0D"
        android:visibility="gone">

        <!-- Panel header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="8dp"
            android:background="#1AFFFFFF">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/panel_playlist_title"
                android:textColor="@color/textPrimary"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium" />

            <ImageButton
                android:id="@+id/btnClosePanel"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_forward"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/controlTint"
                android:contentDescription="关闭列表面板"
                android:rotation="90" />
        </LinearLayout>

        <!-- Playlist items -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvPlaylistPanel"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="8dp" />
    </LinearLayout>

    <!-- ─── Subtitle List Panel (full screen, transparent background set in code) ─── -->
    <LinearLayout
        android:id="@+id/subtitleListPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="#990D0D0D"
        android:visibility="gone">

        <!-- Drag handle indicator (pull down to close) -->
        <View
            android:id="@+id/subtitlePanelDragHandle"
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp"
            android:background="#66FFFFFF" />

        <!-- Panel header: [toggle timestamps] [close arrow-down] -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="8dp">

            <!-- Toggle timestamps button -->
            <TextView
                android:id="@+id/btnToggleTimestamps"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/subtitle_list_hide_time"
                android:textColor="@color/colorAccentLight"
                android:textSize="13sp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground" />

            <!-- Close button (arrow down) -->
            <ImageButton
                android:id="@+id/btnCloseSubtitlePanel"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_arrow_down"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/controlTint"
                android:contentDescription="关闭字幕列表" />
        </LinearLayout>

        <!-- Empty hint -->
        <TextView
            android:id="@+id/tvSubtitleListEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_weight="1"
            android:text="@string/subtitle_list_empty"
            android:textColor="@color/textSecondary"
            android:textSize="14sp"
            android:gravity="center"
            android:visibility="gone" />

        <!-- Subtitle entries list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvSubtitleList"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="8dp" />

    </LinearLayout>

    <!-- ─── Lock Overlay (shown when screen is locked) ─── -->
    <FrameLayout
        android:id="@+id/lockOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <ImageButton
            android:id="@+id/btnUnlock"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="top|start"
            android:layout_margin="16dp"
            android:src="@drawable/ic_lock"
            android:background="#88000000"
            android:tint="@color/colorAccentLight"
            android:contentDescription="@string/btn_unlock"
            android:padding="10dp" />
    </FrameLayout>

</FrameLayout>
