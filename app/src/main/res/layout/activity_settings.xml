<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgDark">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorPrimary"
        app:elevation="4dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:title="@string/settings_title"
            android:titleTextColor="@color/textPrimary" />

    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:id="@+id/settingsRoot"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ── 默认主界面 ── -->
            <TextView
                android:id="@+id/titleDefaultTab"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_default_tab"
                android:textColor="@color/colorAccentLight"
                android:textSize="13sp"
                android:paddingTop="8dp"
                android:paddingBottom="4dp" />

            <RadioGroup
                android:id="@+id/rgDefaultTab"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="4dp" />

            <!-- ── 标签顺序 ── -->
            <TextView
                android:id="@+id/titleTabOrder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_tab_order"
                android:textColor="@color/colorAccentLight"
                android:textSize="13sp"
                android:paddingTop="8dp"
                android:paddingBottom="4dp" />

            <LinearLayout
                android:id="@+id/tabOrderContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="4dp" />

            <!-- ── 列表显示模式 ── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_view_mode"
                android:textColor="@color/colorAccentLight"
                android:textSize="13sp"
                android:paddingTop="8dp"
                android:paddingBottom="4dp" />

            <RadioGroup
                android:id="@+id/rgViewMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/rbViewGrid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_view_grid"
                    android:textColor="@color/textPrimary"
                    android:paddingStart="8dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp" />

                <RadioButton
                    android:id="@+id/rbViewList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_view_list"
                    android:textColor="@color/textPrimary"
                    android:paddingStart="8dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp" />

            </RadioGroup>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="4dp" />

            <!-- ── 竖屏切换手势 ── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_portrait_swipe"
                android:textColor="@color/colorAccentLight"
                android:textSize="13sp"
                android:paddingTop="8dp"
                android:paddingBottom="4dp" />

            <RadioGroup
                android:id="@+id/rgPortraitSwipe"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/rbPortraitVertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/swipe_vertical_desc"
                    android:textColor="@color/textPrimary"
                    android:paddingStart="8dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp" />

                <RadioButton
                    android:id="@+id/rbPortraitHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/swipe_horizontal_desc"
                    android:textColor="@color/textPrimary"
                    android:paddingStart="8dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp" />

            </RadioGroup>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="4dp" />

            <!-- ── 横屏切换手势 ── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_landscape_swipe"
                android:textColor="@color/colorAccentLight"
                android:textSize="13sp"
                android:paddingTop="8dp"
                android:paddingBottom="4dp" />

            <RadioGroup
                android:id="@+id/rgLandscapeSwipe"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/rbLandscapeHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/swipe_horizontal_desc"
                    android:textColor="@color/textPrimary"
                    android:paddingStart="8dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp" />

                <RadioButton
                    android:id="@+id/rbLandscapeVertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/swipe_vertical_desc"
                    android:textColor="@color/textPrimary"
                    android:paddingStart="8dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp" />

            </RadioGroup>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="4dp" />

            <!-- ── 字幕大小 ── -->
            <TextView
                android:id="@+id/tvSubtitleSizeLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_subtitle_size_default"
                android:textColor="@color/colorAccentLight"
                android:textSize="13sp"
                android:paddingTop="8dp"
                android:paddingBottom="4dp" />

            <SeekBar
                android:id="@+id/sbSubtitleSize"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="30"
                android:progressTint="@color/colorAccent"
                android:thumbTint="@color/colorAccent"
                android:layout_marginBottom="8dp" />

            <!-- ── 字幕行间距 ── -->
            <TextView
                android:id="@+id/tvSubtitleLineSpacingLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_subtitle_line_spacing_default"
                android:textColor="@color/colorAccentLight"
                android:textSize="13sp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />

            <SeekBar
                android:id="@+id/sbSubtitleLineSpacing"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="20"
                android:progressTint="@color/colorAccent"
                android:thumbTint="@color/colorAccent"
                android:layout_marginBottom="8dp" />

            <!-- Bottom spacer -->
            <View
                android:layout_width="match_parent"
                android:layout_height="24dp" />

            <!-- Save button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveSettings"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="@string/settings_save"
                android:textColor="@color/textPrimary"
                app:backgroundTint="@color/colorAccent" />

        </LinearLayout>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
