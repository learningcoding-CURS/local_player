<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgDark">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorPrimary"
        app:elevation="4dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:title="@string/settings_title"
            android:titleTextColor="@color/textPrimary" />

    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:id="@+id/settingsRoot"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ── 默认主界面/底部标签/工具栏（可折叠标签切换） ── -->
            <LinearLayout
                android:id="@+id/navTabRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="4dp"
                android:paddingBottom="4dp">

                <TextView android:id="@+id/tabDefaultHome" android:layout_width="0dp" android:layout_weight="1" android:layout_height="36dp" android:text="默认主界面" android:textColor="@color/textPrimary" android:textSize="12sp" android:gravity="center" android:background="@drawable/bg_speed_badge" android:layout_marginEnd="4dp" />
                <TextView android:id="@+id/tabBottomOrder" android:layout_width="0dp" android:layout_weight="1" android:layout_height="36dp" android:text="底部标签" android:textColor="@color/textPrimary" android:textSize="12sp" android:gravity="center" android:background="@drawable/bg_speed_badge" android:layout_marginEnd="4dp" />
                <TextView android:id="@+id/tabToolbarOrder" android:layout_width="0dp" android:layout_weight="1" android:layout_height="36dp" android:text="工具栏" android:textColor="@color/textPrimary" android:textSize="12sp" android:gravity="center" android:background="@drawable/bg_speed_badge" />

            </LinearLayout>

            <LinearLayout android:id="@+id/sectionDefaultHome" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone">
                <RadioGroup android:id="@+id/rgDefaultTab" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" />
            </LinearLayout>

            <LinearLayout android:id="@+id/sectionBottomOrder" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingTop="4dp" android:paddingBottom="4dp">
                    <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="@string/tab_builtin" android:textColor="@color/textPrimary" android:textSize="14sp" />
                    <Switch android:id="@+id/switchBuiltinVisible" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingTop="4dp" android:paddingBottom="4dp">
                    <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="@string/tab_playlist" android:textColor="@color/textPrimary" android:textSize="14sp" />
                    <Switch android:id="@+id/switchPlaylistVisible" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                </LinearLayout>
                <TextView android:id="@+id/titleTabOrder" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/settings_tab_order" android:textColor="@color/colorAccentLight" android:textSize="13sp" android:paddingTop="12dp" android:paddingBottom="4dp" />
                <LinearLayout android:id="@+id/tabOrderContainer" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" />
            </LinearLayout>

            <LinearLayout android:id="@+id/sectionToolbarOrder" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone">
                <TextView android:id="@+id/titleShortcutOrder" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/settings_shortcut_order" android:textColor="@color/colorAccentLight" android:textSize="13sp" android:paddingTop="4dp" android:paddingBottom="4dp" />
                <LinearLayout android:id="@+id/shortcutOrderContainer" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" android:layout_marginTop="4dp" android:layout_marginBottom="4dp" />

            <!-- ── 竖屏手势/横屏手势/面板竖屏/面板横屏（可折叠标签切换） ── -->
            <LinearLayout
                android:id="@+id/generalTabRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="4dp"
                android:paddingBottom="4dp">

                <TextView android:id="@+id/tabPortraitSwipe" android:layout_width="0dp" android:layout_weight="1" android:layout_height="36dp" android:text="竖屏手势" android:textColor="@color/textPrimary" android:textSize="12sp" android:gravity="center" android:background="@drawable/bg_speed_badge" android:layout_marginEnd="4dp" />
                <TextView android:id="@+id/tabLandscapeSwipe" android:layout_width="0dp" android:layout_weight="1" android:layout_height="36dp" android:text="横屏手势" android:textColor="@color/textPrimary" android:textSize="12sp" android:gravity="center" android:background="@drawable/bg_speed_badge" android:layout_marginEnd="4dp" />
                <TextView android:id="@+id/tabPanelPortrait" android:layout_width="0dp" android:layout_weight="1" android:layout_height="36dp" android:text="面板竖屏" android:textColor="@color/textPrimary" android:textSize="12sp" android:gravity="center" android:background="@drawable/bg_speed_badge" android:layout_marginEnd="4dp" />
                <TextView android:id="@+id/tabPanelLandscape" android:layout_width="0dp" android:layout_weight="1" android:layout_height="36dp" android:text="面板横屏" android:textColor="@color/textPrimary" android:textSize="12sp" android:gravity="center" android:background="@drawable/bg_speed_badge" />

            </LinearLayout>

            <LinearLayout android:id="@+id/sectionPortraitSwipe" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone">
                <RadioGroup android:id="@+id/rgPortraitSwipe" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                    <RadioButton android:id="@+id/rbPortraitVertical" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="@string/swipe_vertical_desc" android:textColor="@color/textPrimary" android:paddingStart="4dp" android:paddingTop="6dp" android:paddingBottom="6dp" />
                    <RadioButton android:id="@+id/rbPortraitHorizontal" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="@string/swipe_horizontal_desc" android:textColor="@color/textPrimary" android:paddingStart="4dp" android:paddingTop="6dp" android:paddingBottom="6dp" />
                </RadioGroup>
            </LinearLayout>

            <LinearLayout android:id="@+id/sectionLandscapeSwipe" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone">
                <RadioGroup android:id="@+id/rgLandscapeSwipe" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                    <RadioButton android:id="@+id/rbLandscapeHorizontal" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="@string/swipe_horizontal_desc" android:textColor="@color/textPrimary" android:paddingStart="4dp" android:paddingTop="6dp" android:paddingBottom="6dp" />
                    <RadioButton android:id="@+id/rbLandscapeVertical" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="@string/swipe_vertical_desc" android:textColor="@color/textPrimary" android:paddingStart="4dp" android:paddingTop="6dp" android:paddingBottom="6dp" />
                </RadioGroup>
            </LinearLayout>

            <LinearLayout android:id="@+id/sectionPanelPortrait" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone">
                <LinearLayout android:id="@+id/rgPanelDirPortrait" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <RadioButton android:id="@+id/rbPanelDirPortraitTop" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="@string/panel_dir_top" android:textColor="@color/textPrimary" android:paddingStart="4dp" android:paddingTop="6dp" android:paddingBottom="6dp" />
                        <RadioButton android:id="@+id/rbPanelDirPortraitBottom" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="@string/panel_dir_bottom" android:textColor="@color/textPrimary" android:paddingStart="4dp" android:paddingTop="6dp" android:paddingBottom="6dp" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <RadioButton android:id="@+id/rbPanelDirPortraitLeft" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="@string/panel_dir_left" android:textColor="@color/textPrimary" android:paddingStart="4dp" android:paddingTop="6dp" android:paddingBottom="6dp" />
                        <RadioButton android:id="@+id/rbPanelDirPortraitRight" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="@string/panel_dir_right" android:textColor="@color/textPrimary" android:paddingStart="4dp" android:paddingTop="6dp" android:paddingBottom="6dp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout android:id="@+id/sectionPanelLandscape" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone">
                <LinearLayout android:id="@+id/rgPanelDirLandscape" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <RadioButton android:id="@+id/rbPanelDirLandscapeTop" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="@string/panel_dir_top" android:textColor="@color/textPrimary" android:paddingStart="4dp" android:paddingTop="6dp" android:paddingBottom="6dp" />
                        <RadioButton android:id="@+id/rbPanelDirLandscapeBottom" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="@string/panel_dir_bottom" android:textColor="@color/textPrimary" android:paddingStart="4dp" android:paddingTop="6dp" android:paddingBottom="6dp" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <RadioButton android:id="@+id/rbPanelDirLandscapeLeft" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="@string/panel_dir_left" android:textColor="@color/textPrimary" android:paddingStart="4dp" android:paddingTop="6dp" android:paddingBottom="6dp" />
                        <RadioButton android:id="@+id/rbPanelDirLandscapeRight" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="@string/panel_dir_right" android:textColor="@color/textPrimary" android:paddingStart="4dp" android:paddingTop="6dp" android:paddingBottom="6dp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- ── 列表模式（竖屏手势行下方、字幕大小上方） ── -->
            <LinearLayout
                android:id="@+id/listModeRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="4dp"
                android:paddingBottom="4dp">

                <TextView android:id="@+id/tabViewMode" android:layout_width="match_parent" android:layout_height="36dp" android:text="列表模式" android:textColor="@color/textPrimary" android:textSize="12sp" android:gravity="center" android:background="@drawable/bg_speed_badge" />

            </LinearLayout>

            <LinearLayout android:id="@+id/sectionViewMode" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone">
                <RadioGroup android:id="@+id/rgViewMode" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                    <RadioButton android:id="@+id/rbViewGrid" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="@string/settings_view_grid" android:textColor="@color/textPrimary" android:paddingStart="4dp" android:paddingTop="6dp" android:paddingBottom="6dp" />
                    <RadioButton android:id="@+id/rbViewList" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="@string/settings_view_list" android:textColor="@color/textPrimary" android:paddingStart="4dp" android:paddingTop="6dp" android:paddingBottom="6dp" />
                </RadioGroup>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/settings_grid_size" android:textColor="@color/colorAccentLight" android:textSize="13sp" android:paddingTop="12dp" android:paddingBottom="4dp" />
                <TextView android:id="@+id/tvGridCellWidthLibrary" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/textSecondary" android:textSize="12sp" android:paddingBottom="2dp" />
                <SeekBar android:id="@+id/sbGridCellWidthLibrary" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="140" android:progressTint="@color/colorAccent" android:thumbTint="@color/colorAccent" android:layout_marginBottom="6dp" />
                <TextView android:id="@+id/tvGridCellWidthBuiltin" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/textSecondary" android:textSize="12sp" android:paddingBottom="2dp" />
                <SeekBar android:id="@+id/sbGridCellWidthBuiltin" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="140" android:progressTint="@color/colorAccent" android:thumbTint="@color/colorAccent" android:layout_marginBottom="6dp" />
                <TextView android:id="@+id/tvGridCellWidthPlaylist" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/textSecondary" android:textSize="12sp" android:paddingBottom="2dp" />
                <SeekBar android:id="@+id/sbGridCellWidthPlaylist" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="140" android:progressTint="@color/colorAccent" android:thumbTint="@color/colorAccent" android:layout_marginBottom="6dp" />
                <TextView android:id="@+id/tvGridCellWidthPlaylistItems" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/textSecondary" android:textSize="12sp" android:paddingBottom="2dp" />
                <SeekBar android:id="@+id/sbGridCellWidthPlaylistItems" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="140" android:progressTint="@color/colorAccent" android:thumbTint="@color/colorAccent" android:layout_marginBottom="6dp" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" android:layout_marginTop="4dp" android:layout_marginBottom="4dp" />

            <!-- ── 字幕大小 ── -->
            <TextView
                android:id="@+id/tvSubtitleSizeLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_subtitle_size_default"
                android:textColor="@color/colorAccentLight"
                android:textSize="13sp"
                android:paddingTop="8dp"
                android:paddingBottom="4dp" />

            <SeekBar
                android:id="@+id/sbSubtitleSize"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="30"
                android:progressTint="@color/colorAccent"
                android:thumbTint="@color/colorAccent"
                android:layout_marginBottom="8dp" />

            <!-- ── 字幕行间距 ── -->
            <TextView
                android:id="@+id/tvSubtitleLineSpacingLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_subtitle_line_spacing_default"
                android:textColor="@color/colorAccentLight"
                android:textSize="13sp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />

            <SeekBar
                android:id="@+id/sbSubtitleLineSpacing"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="20"
                android:progressTint="@color/colorAccent"
                android:thumbTint="@color/colorAccent"
                android:layout_marginBottom="8dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="4dp" />

            <!-- ── 按钮调试区（可折叠标签切换） ── -->
            <LinearLayout
                android:id="@+id/btnTuneTabRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="4dp"
                android:paddingBottom="4dp">

                <TextView
                    android:id="@+id/tabSeek"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="36dp"
                    android:text="跳转"
                    android:textColor="@color/textPrimary"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:background="@drawable/bg_speed_badge"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:id="@+id/tabSkip"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="36dp"
                    android:text="切换"
                    android:textColor="@color/textPrimary"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:background="@drawable/bg_speed_badge"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:id="@+id/tabPlayPause"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="36dp"
                    android:text="暂停"
                    android:textColor="@color/textPrimary"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:background="@drawable/bg_speed_badge"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:id="@+id/tabProgress"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="36dp"
                    android:text="进度条"
                    android:textColor="@color/textPrimary"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:background="@drawable/bg_speed_badge" />

            </LinearLayout>

            <!-- ── 跳转按钮（可折叠） ── -->
            <LinearLayout
                android:id="@+id/sectionSeek"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView android:id="@+id/tvSeekIconSizeLabel" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/textSecondary" android:textSize="13sp" android:paddingTop="4dp" android:paddingBottom="2dp" />
                <SeekBar android:id="@+id/sbSeekIconSize" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="128" android:progressTint="@color/colorAccent" android:thumbTint="@color/colorAccent" android:layout_marginBottom="6dp" />

                <TextView android:id="@+id/tvSeekSecondsLabel" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/textSecondary" android:textSize="13sp" android:paddingTop="4dp" android:paddingBottom="2dp" />
                <SeekBar android:id="@+id/sbSeekSeconds" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="59" android:progressTint="@color/colorAccent" android:thumbTint="@color/colorAccent" android:layout_marginBottom="6dp" />

                <TextView android:id="@+id/tvSeekAlphaLabel" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/textSecondary" android:textSize="13sp" android:paddingTop="4dp" android:paddingBottom="2dp" />
                <SeekBar android:id="@+id/sbSeekAlpha" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="90" android:progressTint="@color/colorAccent" android:thumbTint="@color/colorAccent" android:layout_marginBottom="6dp" />

                <TextView android:id="@+id/tvSeekOffsetLabel" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/textSecondary" android:textSize="13sp" android:paddingTop="4dp" android:paddingBottom="2dp" />
                <SeekBar android:id="@+id/sbSeekOffset" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="1000" android:progressTint="@color/colorAccent" android:thumbTint="@color/colorAccent" android:layout_marginBottom="6dp" />
            </LinearLayout>

            <!-- ── 切换按钮（可折叠） ── -->
            <LinearLayout
                android:id="@+id/sectionSkip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView android:id="@+id/tvSkipSizeLabel" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/textSecondary" android:textSize="13sp" android:paddingTop="4dp" android:paddingBottom="2dp" />
                <SeekBar android:id="@+id/sbSkipSize" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="128" android:progressTint="@color/colorAccent" android:thumbTint="@color/colorAccent" android:layout_marginBottom="6dp" />

                <TextView android:id="@+id/tvSkipAlphaLabel" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/textSecondary" android:textSize="13sp" android:paddingTop="4dp" android:paddingBottom="2dp" />
                <SeekBar android:id="@+id/sbSkipAlpha" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="90" android:progressTint="@color/colorAccent" android:thumbTint="@color/colorAccent" android:layout_marginBottom="6dp" />

                <TextView android:id="@+id/tvSkipOffsetLabel" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/textSecondary" android:textSize="13sp" android:paddingTop="4dp" android:paddingBottom="2dp" />
                <SeekBar android:id="@+id/sbSkipOffset" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="1000" android:progressTint="@color/colorAccent" android:thumbTint="@color/colorAccent" android:layout_marginBottom="6dp" />
            </LinearLayout>

            <!-- ── 暂停按钮（可折叠） ── -->
            <LinearLayout
                android:id="@+id/sectionPlayPause"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView android:id="@+id/tvPlayPauseSizeLabel" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/textSecondary" android:textSize="13sp" android:paddingTop="4dp" android:paddingBottom="2dp" />
                <SeekBar android:id="@+id/sbPlayPauseSize" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="128" android:progressTint="@color/colorAccent" android:thumbTint="@color/colorAccent" android:layout_marginBottom="6dp" />

                <TextView android:id="@+id/tvPlayPauseAlphaLabel" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/textSecondary" android:textSize="13sp" android:paddingTop="4dp" android:paddingBottom="2dp" />
                <SeekBar android:id="@+id/sbPlayPauseAlpha" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="90" android:progressTint="@color/colorAccent" android:thumbTint="@color/colorAccent" android:layout_marginBottom="6dp" />

                <TextView android:id="@+id/tvPlayPauseOffsetLabel" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/textSecondary" android:textSize="13sp" android:paddingTop="4dp" android:paddingBottom="2dp" />
                <SeekBar android:id="@+id/sbPlayPauseOffset" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="300" android:progressTint="@color/colorAccent" android:thumbTint="@color/colorAccent" android:layout_marginBottom="6dp" />
            </LinearLayout>

            <!-- ── 进度条（可折叠） ── -->
            <LinearLayout
                android:id="@+id/sectionProgress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView android:id="@+id/tvSeekbarHeightLabel" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/textSecondary" android:textSize="13sp" android:paddingTop="4dp" android:paddingBottom="2dp" />
                <SeekBar android:id="@+id/sbSeekbarHeight" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="16" android:progressTint="@color/colorAccent" android:thumbTint="@color/colorAccent" android:layout_marginBottom="6dp" />

                <TextView android:id="@+id/tvSeekbarProgressAlphaLabel" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/textSecondary" android:textSize="13sp" android:paddingTop="4dp" android:paddingBottom="2dp" />
                <SeekBar android:id="@+id/sbSeekbarProgressAlpha" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="90" android:progressTint="@color/colorAccent" android:thumbTint="@color/colorAccent" android:layout_marginBottom="6dp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="4dp" />

            <!-- ── 设置页背景（单独一行，位于进度条之下、字幕面板之上） ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="4dp"
                android:paddingBottom="4dp">

                <TextView android:id="@+id/tabSettingsBg" android:layout_width="match_parent" android:layout_height="36dp" android:text="设置页背景" android:textColor="@color/textPrimary" android:textSize="12sp" android:gravity="center" android:background="@drawable/bg_speed_badge" />

            </LinearLayout>

            <LinearLayout android:id="@+id/sectionSettingsBg" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone">
                <TextView android:id="@+id/tvSettingsBgAlphaLabel" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/colorAccentLight" android:textSize="13sp" android:paddingTop="4dp" android:paddingBottom="4dp" />
                <SeekBar android:id="@+id/sbSettingsBgAlpha" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="100" android:progressTint="@color/colorAccent" android:thumbTint="@color/colorAccent" android:layout_marginBottom="6dp" />
            </LinearLayout>

            <!-- ── 字幕面板/字幕默认/播放控件（可折叠标签切换） ── -->
            <LinearLayout
                android:id="@+id/miscTabRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="4dp"
                android:paddingBottom="4dp">

                <TextView android:id="@+id/tabSubtitlePanel" android:layout_width="0dp" android:layout_weight="1" android:layout_height="36dp" android:text="字幕面板" android:textColor="@color/textPrimary" android:textSize="12sp" android:gravity="center" android:background="@drawable/bg_speed_badge" android:layout_marginEnd="4dp" />
                <TextView android:id="@+id/tabSubtitleDefault" android:layout_width="0dp" android:layout_weight="1" android:layout_height="36dp" android:text="字幕默认" android:textColor="@color/textPrimary" android:textSize="12sp" android:gravity="center" android:background="@drawable/bg_speed_badge" android:layout_marginEnd="4dp" />
                <TextView android:id="@+id/tabPlayerControls" android:layout_width="0dp" android:layout_weight="1" android:layout_height="36dp" android:text="播放控件" android:textColor="@color/textPrimary" android:textSize="12sp" android:gravity="center" android:background="@drawable/bg_speed_badge" />

            </LinearLayout>

            <LinearLayout android:id="@+id/sectionSubtitlePanel" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone">
                <TextView android:id="@+id/tvSubtitlePanelAlphaLabel" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/settings_subtitle_panel_alpha" android:textColor="@color/colorAccentLight" android:textSize="13sp" android:paddingTop="4dp" android:paddingBottom="4dp" />
                <SeekBar android:id="@+id/sbSubtitlePanelAlpha" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="90" android:progressTint="@color/colorAccent" android:thumbTint="@color/colorAccent" android:layout_marginBottom="6dp" />
            </LinearLayout>

            <LinearLayout android:id="@+id/sectionSubtitleDefault" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingTop="4dp" android:paddingBottom="6dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/settings_subtitle_default_visible" android:textColor="@color/textPrimary" android:textSize="14sp" />
                    <Switch android:id="@+id/swSubtitleDefaultVisible" android:layout_width="wrap_content" android:layout_height="wrap_content" android:thumbTint="@color/colorAccent" android:trackTint="@color/colorAccentLight" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout android:id="@+id/sectionPlayerControls" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/settings_section_player_controls" android:textColor="@color/colorAccentLight" android:textSize="13sp" android:paddingTop="4dp" android:paddingBottom="4dp" />
                <LinearLayout android:id="@+id/playerControlsContainer" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" />
            </LinearLayout>

            <!-- 恢复进入前的设置（位于设置页背景那栏下方、顶栏/中央上方） -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveSettings"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="@string/settings_restore"
                android:textColor="@color/textPrimary"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                app:backgroundTint="@color/bgSurface"
                app:strokeColor="@color/colorAccent"
                app:strokeWidth="1dp" />

            <!-- ── 顶栏/中央按钮排序（可折叠标签切换） ── -->
            <LinearLayout android:id="@+id/btnOrderTabRow" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingTop="4dp" android:paddingBottom="4dp">
                <TextView android:id="@+id/tabTopBtnOrder" android:layout_width="0dp" android:layout_weight="1" android:layout_height="36dp" android:text="顶栏" android:textColor="@color/textPrimary" android:textSize="12sp" android:gravity="center" android:background="@drawable/bg_speed_badge" android:layout_marginEnd="4dp" />
                <TextView android:id="@+id/tabCenterBtnOrder" android:layout_width="0dp" android:layout_weight="1" android:layout_height="36dp" android:text="中央" android:textColor="@color/textPrimary" android:textSize="12sp" android:gravity="center" android:background="@drawable/bg_speed_badge" />
            </LinearLayout>

            <LinearLayout android:id="@+id/sectionTopBtnOrder" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/settings_btn_order_top" android:textColor="@color/colorAccentLight" android:textSize="13sp" android:paddingTop="4dp" android:paddingBottom="4dp" />
                <LinearLayout android:id="@+id/topBtnOrderContainer" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" />
            </LinearLayout>

            <LinearLayout android:id="@+id/sectionCenterBtnOrder" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/settings_btn_order_center" android:textColor="@color/colorAccentLight" android:textSize="13sp" android:paddingTop="4dp" android:paddingBottom="4dp" />
                <LinearLayout android:id="@+id/centerBtnOrderContainer" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" />
            </LinearLayout>

            <!-- Bottom spacer -->
            <View
                android:layout_width="match_parent"
                android:layout_height="24dp" />

        </LinearLayout>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
