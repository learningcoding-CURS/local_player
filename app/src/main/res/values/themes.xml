<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.VideoMaster" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="android:windowBackground">@color/bgDark</item>
        <item name="android:statusBarColor">@color/colorPrimaryDark</item>
        <item name="android:navigationBarColor">@color/bgDark</item>
        <item name="android:textColorPrimary">@color/textPrimary</item>
    </style>

    <!-- Dark dialog style used in PlayerActivity -->
    <style name="DarkDialog" parent="Theme.MaterialComponents.Dialog">
        <item name="colorPrimary">@color/colorAccent</item>
        <item name="android:windowBackground">@color/bgCard</item>
        <item name="android:textColorPrimary">@color/textPrimary</item>
        <item name="android:textColorSecondary">@color/textSecondary</item>
    </style>

    <!-- Speed badge text -->
    <style name="SpeedBadge">
        <item name="android:textColor">@color/colorAccentLight</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:background">@drawable/bg_speed_badge</item>
        <item name="android:paddingStart">8dp</item>
        <item name="android:paddingEnd">8dp</item>
        <item name="android:paddingTop">3dp</item>
        <item name="android:paddingBottom">3dp</item>
    </style>

</resources>
